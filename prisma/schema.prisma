// Prisma schema for AIV ATS (Recruitment) System
// Datasource = Postgres (Supabase).
// NOTE: enum-like fields below are `String` with allowed values documented
// in comments and enforced at the application layer (Zod schemas / API routes).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// role: ADMIN | HR | HIRING_MANAGER | INTERVIEWER
model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          String   @default("HIRING_MANAGER")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hiringRequests   HiringRequest[] @relation("RequestedBy")
  notes            Note[]
  evaluations      Evaluation[]
  activityLogs     ActivityLog[]
  interviewPanels  InterviewPanelist[]
}

// status: SUBMITTED | UNDER_REVIEW | APPROVED | REJECTED | NEEDS_INFO
// priority: LOW | MEDIUM | HIGH | URGENT
model HiringRequest {
  id                   String   @id @default(uuid())
  hiringManagerId      String
  hiringManager        User     @relation("RequestedBy", fields: [hiringManagerId], references: [id])
  jobTitle             String
  team                 String
  headcount            Int
  employmentType       String   @default("long_term_volunteer")
  priority             String   @default("MEDIUM")
  reason               String
  targetOnboardingDate DateTime
  status               String   @default("SUBMITTED")
  reviewerNotes        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  opening JobOpening?
}

// status: OPEN | ON_HOLD | FILLED | CLOSED
model JobOpening {
  id            String   @id @default(uuid())
  requestId     String   @unique
  request       HiringRequest @relation(fields: [requestId], references: [id])
  title         String
  team          String
  jdText        String?
  openingsCount Int
  filledCount   Int      @default(0)
  status        String   @default("OPEN")
  createdAt     DateTime @default(now())

  applications Application[]
}

model Candidate {
  id              String   @id @default(uuid())
  fullName        String
  email           String
  phone           String?
  country         String?
  isReferral      Boolean  @default(false)
  referrer        String?
  talentPool      Boolean  @default(false)
  cvFileUrl       String?
  cvFileName      String?
  skills          String?
  experienceYears Int?
  education       String?
  certifications  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  applications Application[]
  notes        Note[]
}

// stage: APPLIED | CV_SCREENING | CULTURE_FIT | TECHNICAL | OFFER | ONBOARDING | HIRED
// status: ACTIVE | REJECTED | POSITION_FILLED | TALENT_POOL | WITHDRAWN
model Application {
  id                String     @id @default(uuid())
  jobOpeningId      String
  jobOpening        JobOpening @relation(fields: [jobOpeningId], references: [id])
  candidateId       String
  candidate         Candidate  @relation(fields: [candidateId], references: [id])
  source            String?
  stage             String     @default("APPLIED")
  status            String     @default("ACTIVE")
  rejectionReason   String?
  rejectionStage    String?
  matchingScore     Int?
  matchingRationale String?
  fastTrackOverride Boolean    @default(false)
  fastTrackNote     String?
  docusignStatus    String?    @default("not_sent")
  appliedAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  interviews   Interview[]
  emailLogs    EmailLog[]
  activityLogs ActivityLog[]
}

// round: CULTURE_FIT | TECHNICAL
model Interview {
  id            String    @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  round         String
  scheduledAt   DateTime?
  format        String?   @default("Google Meet")
  durationMins  Int?      @default(45)
  inviteText    String?
  createdAt     DateTime  @default(now())

  panelists  InterviewPanelist[]
  evaluation Evaluation?
}

model InterviewPanelist {
  id          String    @id @default(uuid())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
}

// recommendation: ADVANCE | REJECT | HOLD
model Evaluation {
  id             String   @id @default(uuid())
  interviewId    String   @unique
  interview      Interview @relation(fields: [interviewId], references: [id])
  interviewerId  String
  interviewer    User     @relation(fields: [interviewerId], references: [id])
  criteriaScores String
  recommendation String
  notes          String?
  createdAt      DateTime @default(now())
}

model EmailTemplate {
  id           String   @id @default(uuid())
  key          String   @unique
  purpose      String
  subject      String
  body         String
  mergeFields  String
  updatedAt    DateTime @updatedAt
}

model EmailLog {
  id              String      @id @default(uuid())
  applicationId   String
  application     Application @relation(fields: [applicationId], references: [id])
  templateKey     String
  renderedSubject String
  renderedBody    String
  status          String      @default("draft")
  sentAt          DateTime?
  createdAt       DateTime    @default(now())
}

model Note {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  text        String
  createdAt   DateTime  @default(now())
}

model ActivityLog {
  id            String       @id @default(uuid())
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id])
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  action        String
  fromValue     String?
  toValue       String?
  createdAt     DateTime     @default(now())
}